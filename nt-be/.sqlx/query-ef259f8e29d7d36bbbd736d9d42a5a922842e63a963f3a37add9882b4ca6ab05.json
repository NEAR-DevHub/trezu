  "query": "\n        SELECT \n            account_id,\n            token_symbol,\n            token_name,\n            token_decimals,\n            token_icon\n        FROM counterparties\n        WHERE account_id = ANY($1)\n          AND account_type = 'ft_token'\n          AND token_symbol IS NOT NULL\n        ",

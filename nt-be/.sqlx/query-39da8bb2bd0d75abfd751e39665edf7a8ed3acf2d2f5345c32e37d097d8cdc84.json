{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT ab.id, ab.dao_id, ab.name, ab.networks, ab.address, ab.note, ab.created_at,\n                   u.account_id AS created_by_wallet\n            FROM address_book ab\n            LEFT JOIN users u ON u.id = ab.created_by\n            WHERE ab.dao_id = $1\n            ORDER BY ab.created_at DESC\n            ",
